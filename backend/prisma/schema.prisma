generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id           String    @id @default(uuid())
  name         String
  email        String    @unique
  role         String    @default("MEMBER") // ADMIN, MEMBER
  ai_credits   Int       @default(0)
  household_id String
  household    Household @relation(fields: [household_id], references: [id])
  expenses     Expense[]
  diet_logs    DietLog[]
  reminders    Reminder[]
  created_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt
}

model Household {
  id                String       @id @default(uuid())
  name              String
  subscription_tier String       @default("FREE") // FREE, PRO
  users             User[]
  inventory         Inventory[]
  expenses          Expense[]
  reminders         Reminder[]
  created_at        DateTime     @default(now())
  updated_at        DateTime     @updatedAt
}

model Inventory {
  id             String    @id @default(uuid())
  household_id   String
  household      Household @relation(fields: [household_id], references: [id])
  item_name      String
  quantity       Float
  unit           String
  category       String?
  last_restocked DateTime  @default(now())
  created_at     DateTime  @default(now())
  updated_at     DateTime  @updatedAt
}

model Expense {
  id           String    @id @default(uuid())
  household_id String
  household    Household @relation(fields: [household_id], references: [id])
  user_id      String
  user         User      @relation(fields: [user_id], references: [id])
  amount       Float
  category     String
  description  String?
  is_settled   Boolean   @default(false)
  timestamp    DateTime  @default(now())
  created_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt
}

model DietLog {
  id         String   @id @default(uuid())
  user_id    String
  user       User     @relation(fields: [user_id], references: [id])
  meal_name  String
  calories   Int?
  macros     String?  // Store as stringified JSON: '{"protein": 10, "carbs": 20}'
  timestamp  DateTime @default(now())
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
}

model Reminder {
  id           String    @id @default(uuid())
  household_id String
  household    Household @relation(fields: [household_id], references: [id])
  user_id      String?
  user         User?     @relation(fields: [user_id], references: [id])
  type         String    // INVENTORY, DIET, CUSTOM
  message      String
  trigger_time DateTime
  status       String    @default("PENDING") // PENDING, TRIGGERED, COMPLETED
  created_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt
}
